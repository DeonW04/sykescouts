{
  "name": "MeetingPaymentOverride",
  "type": "object",
  "properties": {
    "programme_id": {
      "type": "string",
      "description": "Meeting/programme ID (set this OR event_id, not both)"
    },
    "event_id": {
      "type": "string",
      "description": "Event ID (set this OR programme_id, not both)"
    },
    "member_id": {
      "type": "string",
      "description": "Member ID"
    },
    "override_type": {
      "type": "string",
      "enum": [
        "not_attending",
        "waived"
      ],
      "description": "Override type: not_attending removes expected income, waived keeps attending but marks as intentionally waived"
    },
    "set_by": {
      "type": "string",
      "description": "Email of the user who set this override"
    },
    "notes": {
      "type": "string",
      "description": "Optional notes for the override"
    }
  },
  "required": [
    "member_id",
    "override_type"
  ]
}